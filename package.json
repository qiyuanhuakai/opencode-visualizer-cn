{
  "name": "opencode_visualizer_cn",
  "version": "0.2.0",
  "description": "Vis - OpenCode Visualizer",
  "keywords": [
    "opencode",
    "webui"
  ],
  "homepage": "https://github.com/qiyuanhuakai/opencode-visualizer-cn",
  "license": "MIT",
  "author": "qiyuanhuakai",
  "repository": {
    "url": "https://github.com/qiyuanhuakai/opencode-visualizer-cn"
  },
  "main": "electron/main.js",
  "bin": {
    "vis": "server.js"
  },
  "files": [
    "server.js",
    "dist",
    "electron"
  ],
  "type": "module",
  "scripts": {
    "prepack": "vite build",
    "format": "oxfmt",
    "lint": "oxlint && vue-tsc --noEmit",
    "dev": "vite dev",
    "build": "vite build",
    "test": "vitest run",
    "electron:start": "node scripts/electron-start.mjs",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "vite build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "hono": "^4.12.3",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@kikuchan/hexdump": "0.1.0-alpha.9",
    "@shikijs/markdown-it": "^3.22.0",
    "@shikijs/transformers": "^3.22.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.24",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "markdown-it": "^14.1.1",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "oxlint-tsgolint": "^0.12.2",
    "postcss": "^8.5.6",
    "shiki": "^3.22.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "vitest": "^4.1.2",
    "happy-dom": "^17.0.0",
    "vue": "^3.5.28",
    "vue-tsc": "^3.2.4"
  },
  "packageManager": "pnpm@10.29.3"
}
